{
  "name": "openclaw-caspian",
  "version": "0.1.0",
  "description": "OpenClaw channel plugin for Caspian \u2014 give an OpenClaw agent iMessage, WhatsApp Business, phone/SMS, email, Slack, Discord, Telegram and more behind one Caspian identity.",
  "type": "module",
  "license": "Apache-2.0",
  "author": "Caspian <ayushguptadev1@gmail.com>",
  "homepage": "https://trycaspianai.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TryCaspian/caspian-sdk.git",
    "directory": "packages/openclaw"
  },
  "bugs": {
    "url": "https://github.com/TryCaspian/caspian-sdk/issues"
  },
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "channel",
    "caspian",
    "ai",
    "agents",
    "imessage",
    "whatsapp",
    "sms"
  ],
  "engines": {
    "node": ">=22"
  },
  "files": [
    "dist",
    "index.ts",
    "setup-entry.ts",
    "src",
    "types",
    "openclaw.plugin.json",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "setupEntry": "./setup-entry.ts",
    "channel": {
      "id": "caspian",
      "configuredState": {
        "env": {
          "allOf": [
            "COMM_API_KEY"
          ]
        }
      },
      "label": "Caspian",
      "selectionLabel": "Caspian (one identity, every channel)",
      "detailLabel": "Caspian",
      "docsPath": "/channels/caspian",
      "docsLabel": "caspian",
      "blurb": "one Caspian identity across iMessage, WhatsApp Business, phone/SMS, email, Slack, Discord, Telegram and more.",
      "aliases": [
        "caspian-comm"
      ],
      "systemImage": "antenna.radiowaves.left.and.right",
      "markdownCapable": false
    },
    "install": {
      "clawhubSpec": "clawhub:openclaw-caspian",
      "npmSpec": "openclaw-caspian",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.7.2"
    },
    "compat": {
      "pluginApi": ">=2026.7.2"
    },
    "build": {
      "openclawVersion": "2026.7.2"
    },
    "release": {
      "publishToClawHub": true,
      "publishToNpm": true
    }
  },
  "peerDependencies": {
    "openclaw": ">=2026.7.2"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    }
  },
  "dependencies": {
    "caspian-sdk": "^0.1.2"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsup": "^8.5.0",
    "typescript": "^5.6.0",
    "vitest": "^3.2.6"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  }
}
