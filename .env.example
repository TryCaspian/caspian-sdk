# Adapter configuration (read by caspian_adapters.Settings, env prefix COMM_).
# Per-connection credentials (a bot token, a page token) are supplied at
# connect time, not here — this file holds deployment-level adapter knobs only.

# Comma-separated provider list. Local development: the fakes need no credentials.
COMM_PROVIDERS=fake

# SDK / CLI: where your Caspian gateway lives and the key to use.
# COMM_BASE_URL=
# COMM_API_KEY=

# ---------------------------------------------------------------------------
# Email via AWS SES on your own domain (provider "ses")
# ---------------------------------------------------------------------------
# COMM_PROVIDERS=ses
# COMM_SES_REGION=us-east-1
# COMM_SES_DOMAIN=example.com
# COMM_SES_S3_BUCKET=example-inbound-mail
# COMM_SES_TOPIC_ARN=arn:aws:sns:us-east-1:123456789012:mail-inbound

# ---------------------------------------------------------------------------
# Telegram via the official Bot API (provider "telegram"; developers supply
# their own bot token at connect time — only the webhook base is deployment config)
# ---------------------------------------------------------------------------
# COMM_TELEGRAM_WEBHOOK_BASE=https://<gateway>/internal/providers/telegram/webhooks

# ---------------------------------------------------------------------------
# Telegram user-account provider (provider "telegram-user", MTProto).
# ToS-GRAY: automating a personal account risks the account. Requires explicit
# opt-in configuration — read the README channel notes first.
# Install extra: caspian-adapters[telegram-user]
# ---------------------------------------------------------------------------
# COMM_TELEGRAM_USER_SESSION=
# COMM_TELEGRAM_API_ID=
# COMM_TELEGRAM_API_HASH=

# ---------------------------------------------------------------------------
# Discord (provider "discord"; developers supply their own bot token at
# connect time, or configure ONE shared bot for one-click installs)
# ---------------------------------------------------------------------------
# COMM_DISCORD_CLIENT_ID=
# COMM_DISCORD_CLIENT_SECRET=
# COMM_DISCORD_BOT_TOKEN=

# ---------------------------------------------------------------------------
# Slack (provider "slack", OAuth per workspace). Enable "Token Rotation" on
# the Slack app for short-lived access tokens + refresh tokens.
# ---------------------------------------------------------------------------
# COMM_SLACK_CLIENT_ID=
# COMM_SLACK_CLIENT_SECRET=
# COMM_SLACK_SIGNING_SECRET=

# ---------------------------------------------------------------------------
# GitHub issues / pull-request conversations (provider "github"). Register a
# GitHub App with a Setup URL and webhook URL on your gateway, subscribe to
# issue_comment, and grant Issues read/write. The private key can be an inline
# PEM or a path outside this repository. Never commit the key.
# ---------------------------------------------------------------------------
# COMM_GITHUB_APP_ID=
# COMM_GITHUB_APP_SLUG=
# COMM_GITHUB_PRIVATE_KEY=/path/outside/repo/github-app.pem
# COMM_GITHUB_WEBHOOK_SECRET=
# COMM_GITHUB_API_BASE=https://api.github.com

# ---------------------------------------------------------------------------
# Instagram DM / Facebook Messenger (providers "instagram" / "facebook").
# Your own Meta app + Page: page id and Page access token identify the Page
# the agent answers as; the app secret verifies webhook signatures.
# ---------------------------------------------------------------------------
# COMM_INSTAGRAM_PAGE_ID=
# COMM_INSTAGRAM_ACCESS_TOKEN=
# COMM_INSTAGRAM_APP_SECRET=
# COMM_INSTAGRAM_VERIFY_TOKEN=
# COMM_FACEBOOK_PAGE_ID=
# COMM_FACEBOOK_ACCESS_TOKEN=
# COMM_FACEBOOK_APP_SECRET=
# COMM_FACEBOOK_VERIFY_TOKEN=
# COMM_GRAPH_VERSION=v21.0

# ---------------------------------------------------------------------------
# X / Twitter (provider "x": post tweets + REACTIVE DMs only)
# Scope: the agent posts tweets, and replies when a human DMs it first (the
# sanctioned customer-service pattern). This provider does NOT do cold/bulk or
# unsolicited DM outreach and does NOT create/farm accounts — both are X-ToS
# banned and out of scope. Requirements: PAID DM API access (the free tier is
# write-only), an existing account labelled "Automated", OAuth-connected.
# ---------------------------------------------------------------------------
# COMM_X_API_KEY=
# COMM_X_API_SECRET=
# COMM_X_BEARER_TOKEN=
# COMM_X_ACCESS_TOKEN=
# COMM_X_ACCESS_SECRET=
# COMM_X_USER_ID=
# COMM_X_WEBHOOK_SECRET=

# ---------------------------------------------------------------------------
# Google Meet (provider "google-meet", channel "gmeet"). Control plane only;
# the persona that joins with a virtual mic/camera is an external realtime
# service reached at COMM_GMEET_JOIN_URL. A Google Cloud service account with
# DOMAIN-WIDE DELEGATION impersonates a Workspace user. Keep the key file OUT
# of the repo; NEVER commit it.
# ---------------------------------------------------------------------------
# COMM_GMEET_SA_JSON=/path/outside/repo/meet-sa.json
# COMM_GMEET_IMPERSONATE=agent@yourdomain.com
# COMM_GMEET_JOIN_URL=https://your-realtime-agent.example.com/meet/join
# COMM_GMEET_WEBHOOK_SECRET=

# ---------------------------------------------------------------------------
# SMS via your own GSM modem (provider "gsm-modem": a real SIM in a USB dongle).
# Carrier compliance is your responsibility. Install extra: caspian-adapters[modem]
# ---------------------------------------------------------------------------
# COMM_MODEM_SERIAL_PORT=/dev/ttyUSB0
# COMM_MODEM_MSISDN=+15551234567

# ---------------------------------------------------------------------------
# Hosted / plugin channels (WhatsApp Business, phone/voice, iMessage, RCS)
# are not in this repo. Install a provider package that registers under the
# "caspian.providers" entry-point group, or use Caspian hosted:
# https://trycaspianai.com
# ---------------------------------------------------------------------------
